{
  "name": "@justanarthur/payload-www",
  "description": "Reusable Payload CMS website template — config builder, collections, globals, blocks, fields, access, hooks, metadata (JSON-LD, hreflang), page renderers, and test helpers.",
  "version": "0.3.4",
  "type": "module",
  "private": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    "./translator": {
      "import": {
        "types": "./dist/translator.d.ts",
        "default": "./dist/translator.js"
      }
    },
    "./render-pages": {
      "import": {
        "types": "./dist/render-pages.d.ts",
        "default": "./dist/render-pages.js"
      }
    },
    "./metadata": {
      "import": {
        "types": "./dist/metadata.d.ts",
        "default": "./dist/metadata.js"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/config.d.ts",
        "default": "./dist/config.js"
      }
    },
    "./imagehash": {
      "import": {
        "types": "./dist/imagehash.d.ts",
        "default": "./dist/imagehash.js"
      }
    },
    "./blocks": {
      "import": {
        "types": "./dist/blocks.d.ts",
        "default": "./dist/blocks.js"
      }
    },
    "./collections": {
      "import": {
        "types": "./dist/collections.d.ts",
        "default": "./dist/collections.js"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.js"
      }
    },
    "./pages": {
      "import": {
        "types": "./dist/pages.d.ts",
        "default": "./dist/pages.js"
      }
    },
    "./access": {
      "import": {
        "types": "./dist/access.d.ts",
        "default": "./dist/access.js"
      }
    },
    "./import-map-provider": {
      "import": {
        "types": "./dist/import-map-provider.d.ts",
        "default": "./dist/import-map-provider.js"
      }
    },
    "./fields": {
      "import": {
        "types": "./dist/fields.d.ts",
        "default": "./dist/fields.js"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bunup && node scripts/strip-createRequire.mjs",
    "clean": "rm -rf dist .tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "dependencies": {
    "@justanarthur/payload-imagehash-plugin": "file:../../plugins/imagehash",
    "@justanarthur/payload-plugin-seo": "file:../../plugins/seo",
    "@justanarthur/payload-plugin-translator": "file:../../plugins/translate",
    "@payloadcms/live-preview-react": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "next": "16.2.6",
    "next-intl": "^4.0.0",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "bunup": "^0.16.32",
    "payload": "3.85.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "5.7.3",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "@payloadcms/live-preview-react": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/richtext-lexical": "^3.85.0",
    "@payloadcms/translations": "^3.85.0",
    "@payloadcms/ui": "^3.85.0",
    "next": "^16.2.6",
    "next-intl": "^4.0.0",
    "payload": "^3.85.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "properties": {
    "gitCommitScopeRelatedNames": "payload-www,render,revalidation,www",
    "priority": 1
  }
}
