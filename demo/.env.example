# SQLite database file (default). The demo uses @payloadcms/db-sqlite.
# Use `file:./<path>.db` for a relative path from the demo dir.
DATABASE_URL=file:./demo.db

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used to validate preview requests (the lib's createPreviewHandler reads this)
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE