{
  "name": "@justanarthur/payload-plugin-translator",
  "description": "Translator plugin for Payload CMS — automatic localization via Google, OpenAI, LibreTranslate, or custom resolvers.",
  "version": "1.3.21",
  "type": "module",
  "private": false,
  "files": [
    "dist",
    "README.md"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./jobs": {
      "import": {
        "types": "./dist/jobs.d.ts",
        "default": "./dist/jobs.js"
      }
    },
    "./resolvers/copy": {
      "import": {
        "types": "./dist/resolvers/copy.d.ts",
        "default": "./dist/resolvers/copy.js"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      }
    },
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./resolvers/openAI": {
      "import": {
        "types": "./dist/resolvers/openAI.d.ts",
        "default": "./dist/resolvers/openAI.js"
      }
    },
    "./resolvers/libreTranslate": {
      "import": {
        "types": "./dist/resolvers/libreTranslate.d.ts",
        "default": "./dist/resolvers/libreTranslate.js"
      }
    },
    "./resolvers/types": {
      "import": {
        "types": "./dist/resolvers/types.d.ts",
        "default": "./dist/resolvers/types.js"
      }
    },
    "./resolvers/google": {
      "import": {
        "types": "./dist/resolvers/google.d.ts",
        "default": "./dist/resolvers/google.js"
      }
    },
    "./client.css": "./dist/client.css",
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "NODE_ENV=production bunup",
    "clean": "rm -rf dist .tsbuildinfo",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "dependencies": {
    "bson-objectid": "^2.0.4",
    "he": "^1.2.0"
  },
  "devDependencies": {
    "@payloadcms/translations": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "@types/he": "^1.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "bunup": "^0.16.32",
    "payload": "3.85.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "5.7.3"
  },
  "peerDependencies": {
    "@payloadcms/translations": "^3.85.0",
    "@payloadcms/ui": "^3.85.0",
    "payload": "^3.85.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "bugs": "https://github.com/r1tsuu/payload-enchants/issues",
  "author": "r1tsuu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justAnArthur/payload-starter_translator.git"
  },
  "properties": {
    "gitCommitScopeRelatedNames": "translate,translator,translation",
    "priority": 0
  }
}