{
  "name": "@justanarthur/payload-imagehash-plugin",
  "description": "Payload CMS plugin for automatic Blurhash/Thumbhash encoding of images",
  "version": "3.2.2",
  "type": "module",
  "private": false,
  "files": [
    "dist",
    "README.md"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      }
    },
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "Unlicense",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bunup",
    "clean": "rm -rf dist .tsbuildinfo",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "dependencies": {
    "blurhash": "^2.0.4",
    "minimatch": "^10.0.1",
    "thumbhash": "^0.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.4.1",
    "bunup": "^0.16.32",
    "payload": "3.85.0",
    "typescript": "5.7.3"
  },
  "peerDependencies": {
    "payload": "^3.85.0",
    "sharp": "0.x"
  }
}
