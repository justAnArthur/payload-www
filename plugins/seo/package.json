{
  "name": "@justanarthur/payload-plugin-seo",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "description": "SEO plugin for Payload CMS — adds meta title, description, image and preview fields.",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/exports/client.d.ts",
      "import": "./dist/exports/client.js"
    },
    "./fields": {
      "types": "./dist/exports/fields.d.ts",
      "import": "./dist/exports/fields.js"
    },
    "./fields-components": {
      "types": "./dist/exports/fields-components.d.ts",
      "import": "./dist/exports/fields-components.js"
    },
    "./types": {
      "types": "./dist/exports/types.d.ts",
      "import": "./dist/exports/types.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bun run build.ts",
    "build:bundle": "bun run build.ts",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "clean": "bun run build.ts --clean",
    "lint": "eslint src",
    "lint:fix": "eslint --fix --ext .ts,.tsx src",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "dependencies": {
    "bson-objectid": "^2.0.4"
  },
  "devDependencies": {
    "@payloadcms/translations": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "openai": "^4.52.0",
    "payload": "3.85.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "5.7.3"
  },
  "peerDependencies": {
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/translations": "^3.85.0",
    "@payloadcms/ui": "^3.85.0",
    "openai": "^4.52.0",
    "payload": "^3.85.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
