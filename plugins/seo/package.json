{
  "name": "@justanarthur/payload-plugin-seo",
  "description": "SEO plugin for Payload CMS — adds meta title, description, image and preview fields.",
  "version": "1.3.11",
  "type": "module",
  "private": false,
  "files": [
    "dist",
    "README.md"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      }
    },
    "./fields-components": {
      "import": {
        "types": "./dist/fields-components.d.ts",
        "default": "./dist/fields-components.js"
      }
    },
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./fields": {
      "import": {
        "types": "./dist/fields.d.ts",
        "default": "./dist/fields.js"
      }
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bunup",
    "prepublishOnly": "bun run clean && bun run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bson-objectid": "^2.0.4"
  },
  "devDependencies": {
    "@payloadcms/translations": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "bunup": "^0.16.32",
    "openai": "^4.52.0",
    "payload": "3.85.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "5.7.3",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/translations": "^3.85.0",
    "@payloadcms/ui": "^3.85.0",
    "openai": "^4.52.0",
    "payload": "^3.85.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "properties": {
    "gitCommitScopeRelatedNames": "seo",
    "priority": 0
  }
}